<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="task2.MainWindow"
        Title="task2">

    <StackPanel Margin="16" Spacing="10">
        <TextBlock Text="Enter Worker Data" FontWeight="Bold" FontSize="16"/>

        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBox Name="NameBox" Watermark="Name" Width="120"/>
            <TextBox Name="GenderBox" Watermark="Gender" Width="100"/>
            <TextBox Name="SalaryBox" Watermark="Salary (in hrn.)" Width="100"/>
            <Button Content="Add Worker" Click="AddWorker_Click"/>
        </StackPanel>

        <Button Content="Sort by descending salary" Click="SortBySalary_Click"/>
        <Button Content="Show max salary" Click="ShowMaxSalary_Click"/>

        <TextBlock Text="Workers:" FontWeight="Bold" Margin="0,10,0,0"/>
        <ListBox Name="WorkersList" Height="200"/>

        <TextBlock Text="Result:" FontWeight="Bold" Margin="0,10,0,0"/>
        <TextBlock Name="ResultBlock" TextWrapping="Wrap"/>
    </StackPanel>
</Window>
