<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="task1.MainWindow"
        Title="task1">


    <Border Background="#8AC926"
            CornerRadius="10"
            Padding="15"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="400">

        <StackPanel Margin="10" Spacing="5">
            <TextBlock Text="First Name"/>
            <TextBox Name="FirstNameBox"/>

            <TextBlock Text="Last Name"/>
            <TextBox Name="LastNameBox"/>

            <TextBlock Text="Age"/>
            <TextBox Name="AgeBox"/>

            <TextBlock Text="Height (cm)"/>
            <TextBox Name="HeightBox"/>

            <TextBlock Text="Weight (kg)"/>
            <TextBox Name="WeightBox"/>

            <TextBlock Text="Occupation"/>
            <TextBox Name="OccupationBox"/>

            <CheckBox Name="IsMarriedBox" Content="Married"/>

            <Button Content="Create Person" Click="CreatePerson_Click" Margin="0,10,0,0"/>
            
            <TextBlock Name="ResultTextBlock" TextWrapping="Wrap" Margin="0,10,0,0"/>
        </StackPanel>
    </Border>
</Window>
