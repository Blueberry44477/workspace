<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="task2_cs.MainWindow"
        Title="task2_cs">

    <StackPanel Margin="10" Spacing="10">

        <TextBox Name="VerticesBox" Watermark="Vertex Count"/>

        <TextBox Name="EdgesBox" Watermark="Edges"/>

        <Button Name="BuildBtn" Content="Build"/>

        <Button Name="AdjBtn" Content="Adjacency matrix"/>

        <Button Name="IncBtn" Content="Incidence matrix"/>

        <TextBox Name="Output" AcceptsReturn="True" Height="300"
                 IsReadOnly="True"/>

    </StackPanel>
</Window>
